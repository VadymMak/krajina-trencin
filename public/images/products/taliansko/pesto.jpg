.swiper-slide .button.transparent a, .swiper-slide .button.transparent_2 a {
    border-color: #fff0d3;
    color: #fff0d3 !important;
}
.swiper-slide .button.transparent_2 .white:hover {
    background-color: #fff0d3 !important;
    color: #573823 !important;
}
[data-bullet_style="see_through_ar_visualized"] .slider-pagination .swiper-pagination-switch svg circle:not(.time) {
    fill: rgb(255 240 211 / 30%) !important;
}
.swiper-container .slider-pagination svg circle.time {
    stroke: #fff0d3 !important;
}
body[data-button-style*="slightly_rounded"] #header-outer .widget_shopping_cart a.button { 
  background-color: #fd7235!important;
}

body[data-button-style*="slightly_rounded"] #header-outer .widget_shopping_cart a.button:hover { 
  background-color: #573823!important;
}
.span_12.dark .nectar-woo-flickity[data-controls=arrows-and-text] .nectar-woo-carousel-top a {
    color: #fd7235 !important;
}

.nectar-category-grid[data-text-color=light] .nectar-category-grid-item:hover .content[data-subtext=custom][data-subtext-vis=always] .subtext:after {
    background-color: #fff0d3;
}
.products li.product.minimal .product-add-to-cart a span {
  background-image: linear-gradient(to right, #fd7235 0, #fd7235 100%)!important;
}
.woocommerce-cart .product-name a {
  background-image: linear-gradient(to right, #573823 0, #573823 100%)!important;
}
.woocommerce-checkout-review-order-table .product-info h4 a {
  background-image: linear-gradient(to right, #573823 0, #573823 100%)!important;
}
body .span_12.dark .woocommerce .nectar-woo-flickity[data-controls*=arrows] .next:before, body .span_12.dark .woocommerce .nectar-woo-flickity[data-controls*=arrows] .previous:before {
    background-color: #573823 !important;
}
body .span_12.dark .woocommerce .nectar-woo-flickity[data-controls*=arrows] .next .arrow, body .span_12.dark .woocommerce .nectar-woo-flickity[data-controls*=arrows] .previous .arrow {
    fill: #573823 !important;
}
.auto_meta_overlaid_spaced .masonry-blog-item .article-content-wrap h3 a, .auto_meta_overlaid_spaced .masonry-blog-item .article-content-wrap h3 a:hover, .auto_meta_overlaid_spaced .masonry-blog-item .meta-category a {
    color: #fff0d3 !important;
}
.span_12.dark .nectar_video_lightbox path {
    fill: #573823 !important;
}
.span_12.dark .nectar_video_lightbox.play_button:before {
    border: 5px solid #573823 !important;
}
 .nectar-box-roll .overlaid-content .subheader, #page-header-bg #portfolio-nav a i, body .section-title #portfolio-nav a:hover i, .page-header-no-bg h1, .page-header-no-bg span, #page-header-bg #portfolio-nav a i, #page-header-bg #single-below-header a:hover, #page-header-bg #single-below-header a:focus, #page-header-bg.fullscreen-header .author-section a {
