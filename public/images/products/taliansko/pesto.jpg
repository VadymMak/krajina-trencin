.woocommerce-cart .cart_totals tr:nth-child(3),
.woocommerce-cart .cart_totals tr.payment,
.woocommerce-cart .cart_totals tr[class*="payment"] {
    display: none !important;
}
/* Робимо контейнер з картинкою відносним */
.woocommerce ul.products li.product a.woocommerce-LoopProduct-link {
    position: relative;
    display: block;
    overflow: hidden; /* щоб бейдж не вилазив за межі картинки */
}

/* Стиль бейджа "Vypredané" */
.krajina-out-of-stock-badge {
    position: absolute;
    top: -25px;
    left: -5px;
    background: #c62828;
    color: #ffffff;
    padding: 6px 10px;
    font-size: 13px;
    font-weight: 600;
    border-radius: 4px;
    z-index: 30;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.future-stock-badge,
.future-stock-badge-single {
    background: #bba46e;
    color: #ffffff;
    padding: 4px 10px;
    font-size: 12px;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 8px;
    font-weight: 600;
    text-transform: uppercase;
}


}
.custom-expiry-badge,
.custom-expiry-badge-single {
    background: #d12c2c;
    color: #fff;
    padding: 4px 10px;
    font-size: 12px;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 8px;
    font-weight: 600;
    text-transform: uppercase;
}
.kazi-nobullets ul,
.kazi-nobullets ol{
  list-style: none !important;
  padding-left: 0 !important;
  margin-left: 0 !important;
}

.kazi-nobullets li{
  list-style: none !important;
  margin: 10px 0;
}

/* додатково: прибити маркер навіть якщо тема хитра */
.kazi-nobullets li::marker{
  content: "" !important;
}
/* прибрати стандартні точки */
.kazi-bullets {
  list-style: none !important;
  padding-left: 0 !important;
  margin-left: 0 !important;
}

/* на всякий випадок – кожен li */
.kazi-bullets li {
  list-style: none !important;
  padding-left: 0 !important;
  margin: 12px 0;
}

/* прибити маркер, навіть якщо тема вперта */
.kazi-bullets li::marker {
  content: "" !important;
}
		</style>
